# Production backend environment — copy to .env and fill in secrets

# PostgreSQL connection (Supabase pooler or self-hosted)
DATABASE_URL=postgresql://user:password@host:5432/bantayani

# JWT — generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24

# Comma-separated allowed frontend origins
CORS_ORIGINS=https://your-domain.com

# AI chat (DeepSeek direct API preferred)
DEEPSEEK_API_KEY=
OPENROUTER_API_KEY=
DEEPSEEK_MODEL=deepseek-chat

# Sentinel Hub OAuth2 (Sentinel View panel)
SENTINEL_HUB_CLIENT_ID=
SENTINEL_HUB_CLIENT_SECRET=

# Google Earth Engine service account JSON path (NDVI tiles, claim verification)
GOOGLE_APPLICATION_CREDENTIALS=./credentials/earth-engine-key.json