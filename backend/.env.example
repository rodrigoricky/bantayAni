DATABASE_URL=demo
JWT_SECRET_KEY=generate-with-python-secrets-token_hex-32
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24
CORS_ORIGINS=http://localhost:3000

# DeepSeek direct API (preferred) — get key at https://platform.deepseek.com/
DEEPSEEK_API_KEY=

# OpenRouter fallback (optional)
OPENROUTER_API_KEY=
DEEPSEEK_MODEL=deepseek-chat

# Sentinel Hub (OAuth2 client credentials)
SENTINEL_HUB_CLIENT_ID=
SENTINEL_HUB_CLIENT_SECRET=

# Google Earth Engine (Sentinel-2 / NDVI) — service account JSON, NOT an API key
GOOGLE_APPLICATION_CREDENTIALS=./credentials/earth-engine-key.json

# Base URL for QR code verification links in generated PDFs.
# Use http://localhost:3000 for local demo. Change to production domain when deploying.
VERIFY_BASE_URL=http://localhost:3000