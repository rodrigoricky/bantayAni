# Production frontend environment (used by `npm run build`)
# Point to your deployed API — browser must be able to reach this URL
NEXT_PUBLIC_API_URL=https://api.your-domain.com/api

# Optional: Google Maps JavaScript API key (falls back to Leaflet without it)
NEXT_PUBLIC_GOOGLE_MAPS_KEY=

# Optional: Mapbox token
NEXT_PUBLIC_MAPBOX_TOKEN=